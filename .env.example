# --------------------------------------------------
# General
# --------------------------------------------------

TZ=America/Santo_Domingo
GENERIC_TIMEZONE=America/Santo_Domingo
NODE_ENV=development
APP_ENV=development

# --------------------------------------------------
# PostgreSQL
# --------------------------------------------------

POSTGRES_DB=n8n_dev
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_a_secure_password

# --------------------------------------------------
# n8n
# --------------------------------------------------

N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false

N8N_ENCRYPTION_KEY=replace_with_a_long_random_key
N8N_USER_MANAGEMENT_JWT_SECRET=replace_with_another_long_random_key

N8N_LOG_LEVEL=debug
N8N_LOG_OUTPUT=console

# --------------------------------------------------
# Mock API
# --------------------------------------------------

MOCK_API_PORT=3001
MOCK_API_URL=http://mock-api:3001

# --------------------------------------------------
# Odoo Mock / futuro Odoo real
# --------------------------------------------------

ODOO_BASE_URL=http://mock-api:3001
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_API_KEY=

# --------------------------------------------------
# WhatsApp Mock / futuro WhatsApp real
# --------------------------------------------------

WHATSAPP_API_URL=http://mock-api:3001
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --------------------------------------------------
# OpenAI
# --------------------------------------------------

OPENAI_API_KEY=
OPENAI_MODEL=